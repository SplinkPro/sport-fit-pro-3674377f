# =============================================================================
# Pratibha by SPLINK — Environment Variable Template
# =============================================================================
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# NEVER commit a populated .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (Postgres + Auth + Storage + Edge Functions)
# -----------------------------------------------------------------------------
# Public project URL of the managed backend instance.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"

# Public/anon key. Safe to expose to the browser — RLS enforces row access.
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-jwt>"

# Project reference id (the slug in the URL above).
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# -----------------------------------------------------------------------------
# Optional: end-to-end test harness (Playwright)
# -----------------------------------------------------------------------------
# Base URL Playwright will hit when running `bunx playwright test`.
# Defaults to http://localhost:8080 if unset.
# PLAYWRIGHT_BASE_URL="http://localhost:8080"

# =============================================================================
# Server-side secrets (configured in the backend dashboard, NOT in this file)
# =============================================================================
# The following are stored in the backend secret manager and consumed by
# edge functions only. They are listed here for reference; do not put real
# values in client .env files.
#
#   SUPABASE_SERVICE_ROLE_KEY   — bypass-RLS server key (edge functions only)
#   SUPABASE_DB_URL             — direct Postgres connection string
#   LLM_GATEWAY_API_KEY         — hosted LLM gateway key (edge functions only)
# =============================================================================
